DATABASE_URL="file:./dev.db"
ML_URL="http://localhost:5001"
PORT=5000

# Primary LLM — get key at https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-key-here"
# Comma-separated model fallback list
GEMINI_MODEL="gemini-2.5-flash,gemini-flash-latest,gemini-2.0-flash"

# Optional: free fast LLM — https://console.groq.com
# GROQ_API_KEY="your-groq-key-here"
# GROQ_MODEL="llama-3.3-70b-versatile"

# Which LLM to try first: groq | gemini | auto (default: groq)
LLM_PRIMARY="groq"
